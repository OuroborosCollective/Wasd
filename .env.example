PORT=3000
NODE_ENV=development

# Optional: absolute path to the `client` package when the server runs outside the monorepo root
# (e.g. PM2 cwd is /opt/server only). Example: /opt/areloria/client
# CLIENT_ROOT_DIR=
# Optional: absolute path to repo-root `world-assets/` when PM2 cwd is not the monorepo (serves /world-assets/*)
# WORLD_ASSETS_DIR=/opt/areloria/world-assets
# Optional: client mirror from sync-world-assets (serves /world-assets/* when WORLD_ASSETS_DIR unset)
# MIRRORED_WORLD_ASSETS_DIR=/opt/areloria/client/public/assets/models/world-assets
MCP_ADMIN_TOKEN=
MCP_PUBLIC_SSE_URL=https://your-domain.example/api/mcp/sse
MCP_PUBLIC_MESSAGES_URL=https://your-domain.example/api/mcp/messages?sessionId=<id>
PUBLIC_WEBSOCKET_URL=wss://your-domain.example/ws

# --- GitHub Actions (not read by Node): set in repo Secrets ---
# DEPLOY_VERIFY_BASE_URL=https://your-public-game-domain.tld   # optional; enables HTTPS checks after VPS deploy
# VPS_IP=  VPS_USER=  VPS_SSH_PASSWORD=

# Firebase — use Firebase Console → Project settings → Your apps (Web) for the VITE_* values below.
# Do not paste the old multi-line JSON blob here; use separate VITE_ lines (see end of file).
FIREBASE_PROJECT_ID=your-project-id

# Firebase Admin Config (Server)
# Must be the same Firebase project as the web client (VITE_FIREBASE_*).
#
# Option A — explicit key (recommended on VPS): JSON string, base64(JSON), or path to .json
# FIREBASE_PROJECT_ID=innate-summit-490115-p5
# FIREBASE_SERVICE_ACCOUNT_KEY=/opt/areloria/secrets/firebase-adminsdk.json
#
# Option B — Application Default Credentials (same as Node: admin.credential.applicationDefault())
# Set path to the service account JSON (do not commit the file):
# GOOGLE_APPLICATION_CREDENTIALS=/opt/areloria/secrets/firebase-adminsdk.json
# FIREBASE_PROJECT_ID=your-gcp-project-id
# Leave FIREBASE_SERVICE_ACCOUNT_KEY empty when using only GOOGLE_APPLICATION_CREDENTIALS.
#
# Option C — GCP VM / Cloud Run with attached service account (metadata server):
# FIREBASE_ADMIN_USE_APPLICATION_DEFAULT=1
# FIREBASE_PROJECT_ID=your-gcp-project-id
FIREBASE_SERVICE_ACCOUNT_KEY=

# When Firebase Admin is unset, players are saved to JSON (default: <repo>/data/players.json)
# PLAYER_SAVE_FILE=/var/lib/areloria/players.json

# Persistence: auto (Firestore if configured, else file) | firestore | file | spacetime
# spacetime = preparation driver: players still use PLAYER_SAVE_FILE until Spacetime reducers are wired
# PERSISTENCE_DRIVER=auto
# SPACETIME_DB_URL=wss://your-host:port
# SPACETIME_MODULE_NAME=wasddb
# SPACETIME_PERSIST_FILE_FALLBACK=0
# Optional Bearer token for HTTP/SQL and WS (owner or privileged identity)
# SPACETIME_TOKEN=

# GLB link overrides: default = JSON file game-data/glb-links.json (content root)
# Set to spacetime to use SpacetimeDB table glb_link (publish spacetimedb-modules/areloria-glb first)
# GLB_LINKS_STORE=file
# GLB_LINKS_STORE=spacetime
# Or shorthand: GLB_LINKS_SPACETIME=1 (same as STORE=spacetime when URL + module name exist)
# Dedicated module name for GLB links (falls back to SPACETIME_MODULE_NAME)
# SPACETIME_GLB_MODULE_NAME=areloria-glb
# With GLB_LINKS_STORE=spacetime, also load missing targets from glb-links.json (default on). Set 0 for DB-only.
# GLB_LINKS_MERGE_FILE=0

# WebSocket login: production requires Firebase token unless guest mode is on
# ALLOW_GUEST_LOGIN=1
# In development, socket-id dev login is allowed unless disabled:
# ALLOW_DEV_LOGIN=0
# Strict: only Firebase tokens (no guest / no dev fallback). Fails fast if Admin key missing.
# REQUIRE_FIREBASE_AUTH=1
# Verify Firebase JWT on WS login (default off during development — ship game first). Set 1 to re-enable.
# USE_FIREBASE_WS_LOGIN=0

# --- Client (Vite) Firebase web config — copy from Firebase Console → Web app
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIRESTORE_DATABASE_ID=
# Hide Google/email game login in HUD and do not send JWT on WS (default: disabled). Set 0 to show Firebase login again.
# VITE_DISABLE_FIREBASE_AUTH=1

# Optional: Firebase AI Logic watchdog — sends recent client errors to Gemini and runs only whitelisted fixes (clear token, reconnect WS, rare reload). Needs AI Logic enabled in Firebase console.
# VITE_FIREBASE_AI_WATCHDOG=1
# VITE_FIREBASE_AI_WATCHDOG_MODEL=gemini-2.0-flash

# Optional: stricter per-account WS message cap (rolling 1s window, after login)
# WS_MAX_MESSAGES_PER_PLAYER_UID_PER_SECOND=48

# Optional: ms between entity_sync for clients that send login.clientHints.lowBandwidth (default 400 in GameConfig)
# STATE_BROADCAST_INTERVAL_MOBILE_MS=500

# Optional: load game content from `published-content/current/` (after `pnpm run content:publish`) instead of `game-data/`
# USE_PUBLISHED_CONTENT=1
# Or set absolute path to a pack folder that contains content-pack-manifest.json + same layout as game-data/
# CONTENT_PACK_DIR=/var/lib/areloria/content/current

# No-code content admin (GLB-Links + asset-pools.json) — REST under /api/admin/content
# UI: /admin-content.html (static). ADMIN_PANEL_TOKEN = any secret you invent (long random string, like an API key; do not commit).
# ADMIN_PANEL_TOKEN=
# Or use Firebase ID token only (omit ADMIN_PANEL_TOKEN) with optional uid allowlist:
# ADMIN_UID_ALLOWLIST=uid1,uid2
# Block all writes (GET still works): CONTENT_ADMIN_READONLY=1
# Admin API also exposes: GET .../choices, GET .../glb-gallery-tree, POST .../glb-upload (multipart file + optional folder), POST .../validate-preview, POST .../publish-pack
# Optional: cap admin GLB upload size in MB (default 50, max 120); falls back to MAX_GLB_SIZE_MB if unset
# MAX_ADMIN_GLB_UPLOAD_MB=50

# WebSocket URL for client hints (production: wss://your-domain/ws)
PUBLIC_WEBSOCKET_URL=ws://localhost:3000/ws
# Legacy / other stacks only:
# NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:3000/ws

# No-code admin — long random secret (or omit and use Firebase JWT + ADMIN_UID_ALLOWLIST)
ADMIN_PANEL_TOKEN=
