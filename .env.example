PORT=3000
NODE_ENV=development

# Firebase Configuration (Primary)
FIREBASE_PROJECT_ID=your-project-id

# Firebase Client Config (Browser)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin Config (Server)
FIREBASE_SERVICE_ACCOUNT_KEY=

# WebSocket Configuration (Local Development)
# For production, use Firebase Hosting or a dedicated WebSocket server
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:3000/ws
