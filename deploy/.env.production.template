# =============================================================================
# Areloria / Ouroboros — PRODUCTION .env template (VPS: /opt/areloria/.env)
# =============================================================================
# 1) Kopiere diese Datei auf den Server (niemals ins Git committen):
#    Von deinem PC:  scp deploy/.env.production.template user@DEIN_SERVER:/opt/areloria/.env
# 2) Auf dem Server:  nano /opt/areloria/.env   → Werte ausfüllen
# 3) Firebase JSON:   ./deploy/setup-firebase-service-account.sh /pfad/zum-key.json
# 4) Neustart:        pm2 restart areloria
# Prüfen:              curl -s http://127.0.0.1:3000/health | head -c 2000
# =============================================================================

# --- Kern ---
NODE_ENV=production
PORT=3000

# Pfade (Standard unter /opt/areloria — nur ändern wenn dein Install anders ist)
CLIENT_ROOT_DIR=/opt/areloria/client
# WORLD_ASSETS_DIR=/opt/areloria/world-assets
# GOOGLE_APPLICATION_CREDENTIALS=/opt/areloria/secrets/firebase-adminsdk.json

# --- Öffentliche URLs (Client / Browser) ---
PUBLIC_WEBSOCKET_URL=wss://DEINE-DOMAIN/ws
# NEXT_PUBLIC_WEBSOCKET_URL=   # nur falls du Next/anderes Frontend nutzt

# --- Firebase Web (VITE_* werden beim BUILD des Clients eingebettet — in .env am Repo-Root vor pnpm build setzen) ---
# Auf dem VPS: vor deploy/build dieselben Werte in die .env legen, die `pnpm run build` liest (meist Repo-Root .env).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIRESTORE_DATABASE_ID=
# VITE_DISABLE_FIREBASE_AUTH=0
# VITE_FIREBASE_AI_WATCHDOG=0

# --- Firebase Admin (Server — Token prüfen, Firestore) ---
# Projekt-ID = dieselbe wie in der Firebase Console / VITE_FIREBASE_PROJECT_ID
FIREBASE_PROJECT_ID=

# Variante A: Pfad zur heruntergeladenen Service-Account-JSON (empfohlen)
FIREBASE_SERVICE_ACCOUNT_KEY=/opt/areloria/secrets/firebase-adminsdk.json

# Variante B: nur ADC — dann FIREBASE_SERVICE_ACCOUNT_KEY leer lassen und setzen:
# FIREBASE_SERVICE_ACCOUNT_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=/opt/areloria/secrets/firebase-adminsdk.json

# Variante C: GCP mit Metadaten-Dienstkonto
# FIREBASE_ADMIN_USE_APPLICATION_DEFAULT=1

# --- WebSocket Login ---
# 1 = Firebase JWT auf Login prüfen (für echtes Google-Login im Spiel)
USE_FIREBASE_WS_LOGIN=1
ALLOW_GUEST_LOGIN=1
ALLOW_DEV_LOGIN=0
# REQUIRE_FIREBASE_AUTH=0

# --- Sicherheit / Secrets (selbst erfinden: lange Zufallszeichen) ---
JWT_SECRET=ÄNDERE_MICH_LANG_UND_ZUFÄLLIG
ADMIN_PANEL_TOKEN=ÄNDERE_MICH_LANG_UND_ZUFÄLLIG
# ADMIN_UID_ALLOWLIST=firebaseUid1,firebaseUid2

# --- Datenbank (optional — nur wenn du Postgres nutzt) ---
# PGHOST=
# PGPORT=5432
# PGDATABASE=
# PGUSER=
# PGPASSWORD=
# PGSSL=true

# --- Persistenz ---
# PERSISTENCE_DRIVER=auto
# PLAYER_SAVE_FILE=/opt/areloria/data/players.json

# --- SpacetimeDB (optional) ---
# SPACETIME_DB_URL=
# SPACETIME_MODULE_NAME=
# SPACETIME_TOKEN=
# GLB_LINKS_STORE=file

# --- Admin / Content API ---
# CONTENT_ADMIN_READONLY=0
# MAX_ADMIN_GLB_UPLOAD_MB=50

# --- MCP (optional) ---
# MCP_ADMIN_TOKEN=
# MCP_PUBLIC_SSE_URL=
# MCP_PUBLIC_MESSAGES_URL=

# --- GitHub Actions (nur in GitHub Repo Secrets — NICHT hier für Runtime) ---
# DEPLOY_VERIFY_BASE_URL=https://deine-domain.tld
# VPS_IP=  VPS_USER=  VPS_SSH_PASSWORD=
